{
  "version": 2,
  "buildCommand": "pnpm --filter @workspace/erp build",
  "outputDirectory": "artifacts/erp/dist/public",
  "builds": [
    {
      "src": "src/index.ts",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/src/index.ts"
    },
    { "handle": "filesystem" },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}